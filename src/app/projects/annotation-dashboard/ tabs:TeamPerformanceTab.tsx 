"use client";
import {
  ResponsiveContainer, LineChart, Line, BarChart, Bar,
  XAxis, YAxis, CartesianGrid, Tooltip,
} from "recharts";
import { DashboardChartCard } from "../DashboardChartCard";
import { CHART_COLORS, CHART_THEME } from "../chartTheme";

interface Props {
  isDark: boolean;
   typeof import("../dashboardData").SEED_DATA;
}

const DAYS = ["mon", "tue", "wed", "thu", "fri"] as const;
const DAY_LABELS = ["Mon", "Tue", "Wed", "Thu", "Fri"];

function heatCell(v: number) {
  if (v >= 95) return "bg-emerald-500 text-white";
  if (v >= 88) return "bg-emerald-300 text-emerald-900 dark:text-emerald-950";
  return "bg-amber-200 text-amber-900 dark:text-amber-950";
}

export function TeamPerformanceTab({ isDark, data }: Props) {
  const theme = isDark ? CHART_THEME.dark : CHART_THEME.light;

  return (
    <div className="space-y-4">
      {/* Member cards */}
      <div className="grid grid-cols-2 gap-3 sm:grid-cols-3 lg:grid-cols-6">
        {data.teamData.members.map((m) => (
          <div key={m.name} className="rounded-xl border border-border bg-card p-3 text-center space-y-1">
            <div className="mx-auto h-10 w-10 rounded-full flex items-center justify-center text-sm font-bold"
              style={{ backgroundColor: CHART_COLORS[0] + "30", color: CHART_COLORS[0] }}>
              {m.avatar}
            </div>
            <p className="text-xs font-semibold text-foreground leading-tight">{m.name.split(" ")[0]}</p>
            <p className="text-lg font-bold text-foreground tabular-nums">{m.productivity}%</p>
            <p className="text-xs text-muted-foreground">{m.tasksCompleted} tasks</p>
            <p className="text-xs text-muted-foreground">{m.avgTaskTime}h avg</p>
          </div>
        ))}
      </div>

      <div className="grid grid-cols-1 gap-4 lg:grid-cols-2">
        <DashboardChartCard title="Team Productivity Trend" subtitle="Last 25 days (100 = target)">
          <ResponsiveContainer width="100%" height={220}>
            <LineChart data={data.teamData.productivity}>
              <CartesianGrid strokeDasharray="3 3" stroke={theme.grid} />
              <XAxis dataKey="date" tick={{ fill: theme.text, fontSize: 10 }} interval={6}
                tickFormatter={(v) => new Date(v).toLocaleDateString("en-US", { month: "short", day: "numeric" })} />
              <YAxis domain={[75, 110]} tick={{ fill: theme.text, fontSize: 11 }} />
              <Tooltip
                contentStyle={{ background: theme.tooltip.bg, border: `1px solid ${theme.tooltip.border}`, borderRadius: 8 }}
                labelFormatter={(v) => new Date(v).toLocaleDateString()}
              />
              <Line type="monotone" dataKey="value" stroke={CHART_COLORS[0]} strokeWidth={2} dot={false} />
            </LineChart>
          </ResponsiveContainer>
        </DashboardChartCard>

        <DashboardChartCard title="Tasks Completed" subtitle="By team member">
          <ResponsiveContainer width="100%" height={220}>
            <BarChart data={data.teamData.members} layout="vertical">
              <CartesianGrid strokeDasharray="3 3" stroke={theme.grid} />
              <XAxis type="number" tick={{ fill: theme.text, fontSize: 11 }} />
              <YAxis dataKey="name" type="category" tick={{ fill: theme.text, fontSize: 10 }} width={90}
                tickFormatter={(v) => v.split(" ")[0]} />
              <Tooltip
                contentStyle={{ background: theme.tooltip.bg, border: `1px solid ${theme.tooltip.border}`, borderRadius: 8 }}
              />
              <Bar dataKey="tasksCompleted" fill={CHART_COLORS[1]} radius={[0, 4, 4, 0]} />
            </BarChart>
          </ResponsiveContainer>
        </DashboardChartCard>
      </div>

      {/* Utilization heatmap */}
      <DashboardChartCard title="Weekly Utilization Heatmap" subtitle="% utilization Mon–Fri">
        <div className="overflow-x-auto">
          <table className="w-full text-xs">
            <thead>
              <tr>
                <th className="text-left py-1 pr-4 text-muted-foreground font-medium">Member</th>
                {DAY_LABELS.map((d) => (
                  <th key={d} className="text-center py-1 px-2 text-muted-foreground font-medium">{d}</th>
                ))}
              </tr>
            </thead>
            <tbody>
              {data.teamData.utilization.map((row) => (
                <tr key={row.member}>
                  <td className="py-1 pr-4 text-muted-foreground whitespace-nowrap">{row.member.split(" ")[0]}</td>
                  {DAYS.map((day) => (
                    <td key={day} className="py-1 px-1 text-center">
                      <span className={`inline-block rounded px-2 py-0.5 font-semibold tabular-nums ${heatCell(row[day])}`}>
                        {row[day]}%
                      </span>
                    </td>
                  ))}
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </DashboardChartCard>
    </div>
  );
}
